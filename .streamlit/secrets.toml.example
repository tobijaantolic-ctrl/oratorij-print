# ──────────────────────────────────────────────────────────────────────────
# secrets.toml — KOPIRAJ V `secrets.toml` IN ZAMENJAJ VREDNOSTI
# Lokalno: ta fajl. Streamlit Cloud: prilepi vsebino pod Settings → Secrets.
# NIKOLI NE COMMITAJ pravega secrets.toml v git!
# ──────────────────────────────────────────────────────────────────────────

# Geslo za /admin stran
admin_password = "zamenjaj-me"

# ID Google Drive mape kamor se uploadajo fajli
# Dobiš ga iz URL-ja: https://drive.google.com/drive/folders/<TO-JE-ID>
drive_folder_id = "PASTE_DRIVE_FOLDER_ID_HERE"

# ID Google Sheet kamor se zapisuje metadata
# Dobiš ga iz URL-ja: https://docs.google.com/spreadsheets/d/<TO-JE-ID>/edit
sheet_id = "PASTE_SHEET_ID_HERE"

# OAuth user credentials (refresh_token) za Drive upload.
# Ker service-accounti nimajo Drive storage quote, uporabnik (Tobija) avtorizira
# app prek OAuth — fajli gredo v njegov Drive.
#
# Pridobi te 3 vrednosti tako, da lokalno zaženeš:
#   pip install google-auth-oauthlib
#   python scripts/get_refresh_token.py credentials/client_secret_*.json
[google_oauth]
client_id = "..."
client_secret = "..."
refresh_token = "..."

# Service account JSON (iz Google Cloud Console) — uporablja se SAMO za Sheets.
# Email service accounta MORA imeti Editor permission na Sheet.
[gcp_service_account]
type = "service_account"
project_id = "your-gcp-project"
private_key_id = "..."
private_key = """-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----
"""
client_email = "your-sa@your-gcp-project.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
